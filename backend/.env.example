# Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# LLM API Keys
GROQ_API_KEY=your_groq_api_key_here
HF_API_TOKEN=your_huggingface_api_token_here

# Database Configuration
SQLITE_PATH=data/nueuro_agents.db
MONGO_URI=mongodb://localhost:27017/nueuro_agents

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# Rate Limiting
RATELIMIT_REQUESTS=100
RATELIMIT_WINDOW=3600

# LLM Model Configuration
# Planner uses Groq (fast, free tier, unlimited)
# Other agents use HuggingFace (lightweight, cost-efficient)
PLANNER_MODEL=llama-3.3-70b-versatile
RESEARCHER_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
ANALYST_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
WRITER_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
REVIEWER_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Graph Configuration
AGENT_TIMEOUT=25
GRAPH_TIMEOUT=30
MAX_ITERATIONS=3
MAX_QUERY_LENGTH=500

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/nueuro_agents.log

# LLM Timeouts & Retries
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
