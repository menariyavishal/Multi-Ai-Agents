# Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ========== LLM API Keys ==========
# Groq - Free tier, unlimited, fast model serving
GROQ_API_KEY=your_groq_api_key_here

# ========== Real-Time Data Source APIs ==========
# Weather Data - OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key_here

# News Data - NewsAPI
NEWS_API_KEY=your_news_api_key_here

# Financial Data - Alpha Vantage
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Web Search - Google Custom Search API
# Get from: https://console.cloud.google.com/apis/dashboard
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here

# Google Custom Search Engine ID (cx parameter)
# Create at: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id_here

# ========== Database Configuration ==========
# MongoDB for conversation history (local or cloud)
# Local development: mongodb://localhost:27017/multi_ai_agents
# MongoDB Atlas (cloud): mongodb+srv://username:password@cluster.mongodb.net/multi_ai_agents?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/multi_ai_agents
MONGODB_DB_NAME=multi_ai_agents

# Optional: SQLite for other data (legacy)
# SQLITE_PATH=data/nueuro_agents.db

# ========== Flask Configuration ==========
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# ========== Rate Limiting ==========
RATELIMIT_REQUESTS=100
RATELIMIT_WINDOW=3600

# ========== Agent Configuration ==========
# All agents use Groq llama-3.3-70b-versatile
# Planner: temp 0.3 (balanced planning)
# Researcher: temp 0.2 (analytical data gathering)
# Analyst: temp 0.1 (precise analysis)
# Writer: temp 0.7 (creative content)
# Reviewer: temp 0.0 (strict deterministic review)

# ========== Graph Configuration ==========
AGENT_TIMEOUT=25
GRAPH_TIMEOUT=30
MAX_ITERATIONS=3
MAX_QUERY_LENGTH=500

# ========== Logging ==========
LOG_LEVEL=INFO
LOG_FILE=logs/nueuro_agents.log

# ========== LLM Timeouts & Retries ==========
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
