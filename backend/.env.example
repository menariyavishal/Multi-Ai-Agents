# Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ========== LLM API Keys ==========
# Groq - Free tier, unlimited, fast model serving
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace - For future agents (Writer, Analyst, Reviewer)
HF_API_TOKEN=your_huggingface_api_token_here

# ========== Real-Time Data Source APIs ==========
# Weather Data - OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_api_key_here

# News Data - NewsAPI
NEWS_API_KEY=your_news_api_key_here

# Financial Data - Alpha Vantage
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ========== Database Configuration ==========
SQLITE_PATH=data/nueuro_agents.db
MONGO_URI=mongodb://localhost:27017/nueuro_agents

# ========== Flask Configuration ==========
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# ========== Rate Limiting ==========
RATELIMIT_REQUESTS=100
RATELIMIT_WINDOW=3600

# ========== Agent Configuration ==========
# Planner: Groq llama-3.3-70b-versatile (temp: 0.3)
# Researcher: Groq llama-3.3-70b-versatile (temp: 0.2)
# Writer: HuggingFace TinyLlama (temp: 0.7) - Not yet implemented
# Analyst: HuggingFace TinyLlama (temp: 0.1) - Not yet implemented
# Reviewer: HuggingFace TinyLlama (temp: 0.5) - Not yet implemented

# ========== Graph Configuration ==========
AGENT_TIMEOUT=25
GRAPH_TIMEOUT=30
MAX_ITERATIONS=3
MAX_QUERY_LENGTH=500

# ========== Logging ==========
LOG_LEVEL=INFO
LOG_FILE=logs/nueuro_agents.log

# ========== LLM Timeouts & Retries ==========
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
