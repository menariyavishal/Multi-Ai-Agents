# Environment Configuration
# Copy this file to .env and fill in your actual values

# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
HF_API_TOKEN=your_huggingface_api_token_here

# Database Configuration
SQLITE_PATH=data/nueuro_agents.db
MONGO_URI=mongodb://localhost:27017/nueuro_agents

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# Rate Limiting
RATELIMIT_REQUESTS=100
RATELIMIT_WINDOW=3600

# LLM Model Configuration
PLANNER_MODEL=gemini-2.0-flash
RESEARCHER_MODEL=mistral-7b
ANALYST_MODEL=llama-3-8b
WRITER_MODEL=gemini-2.0-flash
REVIEWER_MODEL=zephyr-7b

# Graph Configuration
AGENT_TIMEOUT=25
GRAPH_TIMEOUT=30
MAX_ITERATIONS=3
MAX_QUERY_LENGTH=500

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/nueuro_agents.log
